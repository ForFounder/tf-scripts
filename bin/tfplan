#!/usr/bin/env bash

# source tfcommon from same bin folder
. "$(dirname $(realpath $0))/tfcommon"

echo "Current working directory: $(pwd)"
# echo "Files in current directory: $(ls -la)"
echo "Detected folder ${folder}, env ${env}"

usage() {
  echo "Usage: $0 [folder|folder/env]"
  echo "Example: $0 aws"
  echo "Example: $0 aws/dev"
  exit 1
}

if [[ "$1" == "-h" || "$1" == "--help" ]]; then
  usage
fi

echo "tf plan $folder"

is_tf_folder "$folder" || exit 1

setupworkfolder $folder || { echo "Failed to setup work folder $folder"; exit 1; }

terraform fmt -check -v

terraform init

terraform plan -input=false -out plan.tfplan
plan_exit=$?

target="${folder}${env:+/$env}"
if [[ $plan_exit -eq 0 ]]; then
  echo -e "\e[34mPlan for ${target} complete SUCCESS\e[0m"
else
  echo -e "\e[31mPlan for ${target} FAILED\e[0m"
fi
exit $plan_exit

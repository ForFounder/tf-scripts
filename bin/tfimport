#!/usr/bin/env bash

# source tfcommon from same bin folder
. "$(dirname $(realpath $0))/tfcommon"

usage() {
  echo "Usage: $0 [folder|folder/env] <resource_path> <resource_id>"
  echo "Example: $0 aws aws_s3_bucket.example my-bucket"
  exit 1
}

if [[ "$1" == "-h" || "$1" == "--help" ]]; then
  usage
fi

echo "checking $folder"

is_tf_folder "$folder" || exit 1

setupworkfolder $folder || { echo "Failed to setup work folder $folder"; exit 1; }

resource_path=${2}
resource_id=${3}

if [[ -z "$resource_path" ]] || [[ -z "$resource_id" ]]; then
  echo "Error: import requires both <resource_path> and <resource_id>."
  usage
fi

terraform init -migrate-state -upgrade

terraform import -input=false ${resource_path} ${resource_id}
